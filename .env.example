# =============================================================================
# SeedhaHisaab Backend - Environment Variables
# -----------------------------------------------------------------------------
# 1. Copy this file:        cp .env.example .env
# 2. Edit `.env` and fill in real values (especially SESSION_SECRET).
# 3. NEVER commit `.env` to git — it is already in .gitignore.
# =============================================================================

# ---- PostgreSQL credentials (used by docker-compose.yml) -------------------
# These are the credentials docker-compose will create the DB with.
# If you change them after the first run, you must also wipe the volume:
#     docker compose down -v
POSTGRES_USER=seedhahisaab
POSTGRES_PASSWORD=seedhahisaab
POSTGRES_DB=seedhahisaab

# ---- JWT signing key (REQUIRED) --------------------------------------------
# Used by JwtUtil.java to sign session tokens.
# Generate a strong random value, e.g.:
#     openssl rand -base64 48
SESSION_SECRET=replace-me-with-a-long-random-string-at-least-32-bytes

# ---- CORS ------------------------------------------------------------------
# The exact origin (scheme + host + port) of your frontend. The backend will
# reject browser requests from any other origin.
CORS_ALLOWED_ORIGIN=http://localhost:5173

# ---- Standalone (NON-Docker) DB connection ---------------------------------
# Only needed when running the app outside Docker (e.g. `mvn spring-boot:run`).
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# Uncomment and edit if your DB is not on localhost:5432.
# DATABASE_URL=postgresql://seedhahisaab:seedhahisaab@localhost:5432/seedhahisaab
